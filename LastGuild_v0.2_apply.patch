+.preset-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 9px; margin: 18px 0; }
+.preset-grid button { display: grid; grid-template-columns: auto 1fr; gap: 2px 8px; text-align: left; border: 1px solid rgba(55,37,17,.24); background: rgba(255,255,255,.12); color: var(--ink); padding: 13px; cursor: pointer; }
+.preset-grid button svg { grid-row: 1 / 3; color: #765324; }
+.preset-grid button strong { font-size: .73rem; }
+.preset-grid button span { color: #75644e; font-size: .6rem; line-height: 1.35; }
+.preset-grid button.active { border-color: #765324; background: rgba(117,82,35,.17); box-shadow: inset 0 0 0 1px rgba(117,82,35,.22); }
+.world-settings-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }
+.world-settings-grid > section { border: 1px solid rgba(57,38,18,.22); padding: 16px; background: rgba(255,255,255,.08); }
+.world-settings-grid h3 { display: flex; align-items: center; gap: 7px; margin-bottom: 13px; }
+.world-settings-grid h3 svg { color: #765324; }
+.world-settings-grid label { display: grid; grid-template-columns: 1fr minmax(150px, .8fr); align-items: center; gap: 12px; margin: 9px 0; color: #5e4e39; font-size: .67rem; }
+.world-settings-grid label span { display: flex; justify-content: space-between; }
+.world-settings-grid select, .world-settings-grid input[type='range'] { width: 100%; }
+.world-settings-grid select { padding: 8px; border: 1px solid rgba(61,41,19,.3); background: rgba(255,255,255,.18); color: var(--ink); }
+.setting-warning { display: grid; grid-template-columns: auto 1fr; gap: 8px; align-items: start; padding: 10px; margin-top: 12px; background: rgba(139,62,45,.08); color: #754536; }
+.setting-warning p { font-size: .62rem; margin: 0; }
+.difficulty-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 5px; }
+.difficulty-grid button { border: 1px solid rgba(57,38,18,.25); background: rgba(255,255,255,.12); color: var(--ink); padding: 9px 5px; cursor: pointer; }
+.difficulty-grid button strong, .difficulty-grid button span { display: block; }
+.difficulty-grid button strong { font-size: .65rem; }
+.difficulty-grid button span { color: #786750; font-size: .52rem; margin-top: 2px; }
+.difficulty-grid button.active { background: #674523; color: #f0dfb8; }
+.difficulty-grid button.active span { color: #d1bd91; }
+.difficulty-rules { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px; }
+.difficulty-rules span { padding: 4px 6px; border: 1px solid rgba(55,37,17,.2); color: #6c5b45; font-size: .57rem; }
+.world-setup-footer { display: grid; grid-template-columns: minmax(250px, .7fr) 1fr auto; gap: 12px; align-items: end; margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(60,40,18,.25); }
+.seed-field { display: grid; gap: 5px; color: #5f4e38; font-size: .65rem; }
+.seed-field > div { display: grid; grid-template-columns: 1fr auto; }
+.seed-field input { padding: 10px; border: 1px solid rgba(60,40,18,.35); background: rgba(255,255,255,.18); color: var(--ink); min-width: 0; }
+.seed-field button { border: 1px solid rgba(60,40,18,.35); border-left: 0; background: rgba(103,69,35,.13); color: #6e4b24; cursor: pointer; }
+.world-create-summary { display: flex; gap: 8px; align-items: center; color: #6d5d47; font-size: .61rem; line-height: 1.4; }
+.world-create-summary svg { color: #765324; flex: 0 0 auto; }
+.create-world-button { min-height: 42px; }
+
+.map-layers { flex-wrap: wrap; justify-content: flex-end; }
+.map-label { fill: #ead9b3; stroke: #1a130b; stroke-width: 2.2px; paint-order: stroke; font-size: 7px; font-family: Inter, sans-serif; pointer-events: none; }
+.map-legend { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px; color: #887e6e; font-size: .61rem; }
+.map-legend span { display: flex; align-items: center; gap: 5px; }
+.map-legend i { width: 18px; height: 3px; display: inline-block; }
+.legend-road { background: #806f55; }
+.legend-trade { background: #d1ad65; }
+.legend-river { background: #5c91a7; }
+.legend-settlement { width: 7px !important; height: 7px !important; border-radius: 50%; background: #e3c88d; }
+.legend-site { width: 0 !important; height: 0 !important; border-left: 5px solid transparent; border-right: 5px solid transparent; border-bottom: 9px solid #a85041; }
+.realm-detail { border-left: 3px solid; }
+.realm-detail h3 { display: flex; align-items: center; gap: 5px; }
+.site-layers { display: grid; gap: 3px; margin: 8px 0; color: #6e5c44; font-size: .61rem; }
+
+.required-role-line { color: #785f3e; font-size: .61rem; margin: -5px 0 10px; }
+.role-coverage { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 9px; }
+.role-coverage span { display: flex; align-items: center; gap: 3px; padding: 4px 6px; border: 1px solid rgba(139,62,45,.28); color: #883d2f; font-size: .58rem; }
+.role-coverage span.covered { border-color: rgba(79,103,45,.35); color: #52652f; background: rgba(80,105,46,.08); }
+.route-summary { display: flex; align-items: center; gap: 7px; padding: 9px; background: rgba(70,49,24,.09); color: #64543e; font-size: .67rem; }
+.risk-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 5px; }
+.risk-cell { display: flex; justify-content: space-between; gap: 4px; padding: 7px; border: 1px solid rgba(56,38,18,.2); font-size: .57rem; }
+.risk-cell.low { background: rgba(79,103,45,.1); }
+.risk-cell.medium { background: rgba(174,132,49,.11); }
+.risk-cell.high { background: rgba(150,80,42,.12); }
+.risk-cell.critical { background: rgba(143,51,42,.18); color: #7e3027; }
+.range-field em { font-style: normal; color: #8b7659; font-size: .55rem; }
+
+.decision-backdrop { z-index: 160; }
+.decision-modal { width: min(690px, 100%); padding: 30px; color: var(--ink); position: relative; }
+.decision-icon { position: absolute; right: 25px; top: 25px; color: #8b3e32; }
+.decision-modal h2 { font-size: 2.25rem; padding-right: 40px; }
+.decision-modal > p:not(.eyebrow) { color: #62523e; font-size: .76rem; }
+.decision-context { display: flex; align-items: center; gap: 7px; padding: 9px 11px; border: 1px solid rgba(56,38,18,.2); color: #705f49; font-size: .63rem; }
+.decision-choices { display: grid; gap: 8px; margin: 17px 0; }
+.decision-choices button { display: grid; text-align: left; border: 1px solid rgba(58,39,18,.26); background: rgba(255,255,255,.12); color: var(--ink); padding: 13px 14px; cursor: pointer; }
+.decision-choices button:hover { border-color: #765324; background: rgba(111,77,34,.13); transform: translateY(-1px); }
+.decision-choices strong { font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; }
+.decision-choices span { color: #6f5f49; font-size: .64rem; margin-top: 2px; }
+.decision-choices small { color: #8a6941; font-size: .55rem; margin-top: 5px; }
+.decision-note { display: flex; align-items: center; gap: 5px; color: #8b3e32; font-size: .58rem; }
+
+@media (max-width: 900px) {
+  .preset-grid { grid-template-columns: 1fr 1fr; }
+  .world-settings-grid { grid-template-columns: 1fr; }
+  .world-setup-footer { grid-template-columns: 1fr; }
+  .difficulty-grid { grid-template-columns: 1fr 1fr; }
+}
+
+@media (max-width: 600px) {
+  .world-setup-modal { padding: 20px; margin: 0; }
+  .world-setup-header { display: block; }
+  .world-build-summary { text-align: left; margin-top: 10px; }
+  .preset-grid { grid-template-columns: 1fr; }
+  .world-settings-grid label { grid-template-columns: 1fr; }
+  .risk-grid { grid-template-columns: 1fr 1fr; }
+  .decision-modal { padding: 22px; }
+}
